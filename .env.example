# Database
DATABASE_URL=postgresql://...

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                        # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
INITIAL_ADMIN_EMAIL=you@gmail.com       # First login with this email gets super-admin

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://media.yourdomain.com  # CF CDN subdomain pointing at R2

# Site URL (used in social media post links)
SITE_URL=https://capturewashington.org

# Bluesky (AT Protocol)
BLUESKY_HANDLE=                            # e.g. yourhandle.bsky.social
BLUESKY_APP_PASSWORD=                      # Generate at bsky.app/settings/app-passwords

# Instagram (Graph API)
INSTAGRAM_USER_ID=                         # Instagram Business account user ID
INSTAGRAM_ACCESS_TOKEN=                    # Long-lived access token (60-day validity)
INSTAGRAM_APP_SECRET=                      # App secret for token refresh
